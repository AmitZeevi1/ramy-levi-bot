# ─────────────────────────────────────────────
# Green API credentials
# Sign up free at https://green-api.com
# After creating an instance, find these in your instance dashboard
# ─────────────────────────────────────────────
GREEN_API_INSTANCE_ID=1101234567
GREEN_API_TOKEN=your_token_here

# ─────────────────────────────────────────────
# Rami Levy API credentials
#
# How to get these:
#   1. Go to https://www.rami-levy.co.il and log in
#   2. Open DevTools (F12) → Network tab
#   3. Search for any product on the site
#   4. Click on any /api/catalog request
#   5. Copy from Request Headers:
#      - Authorization header → everything after "Bearer "
#      - ecomtoken header     → full value
#      - cookie header        → full value
# ─────────────────────────────────────────────
RAMI_LEVY_API_KEY=your_bearer_token_here
RAMI_LEVY_ECOM_TOKEN=your_ecom_token_here
RAMI_LEVY_COOKIE=your_cookie_string_here

# Store ID (find yours by inspecting a cart POST on the site)
# Common: 331=Jerusalem Talpiot, 10=Tel Aviv, 111=Haifa
RAMI_LEVY_STORE_ID=331

# Port — Render sets this automatically, leave as 3000 for local
PORT=3000
