# Telegram Bot token — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed to use the bot
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_TELEGRAM_IDS=123456789,987654321

# Rami Levy store ID (331 = Jerusalem Talpiot, 10 = Tel Aviv, 111 = Haifa)
RAMI_LEVY_STORE_ID=331

# Claude API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — get from your project settings at supabase.com
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Optional: pre-seed Rami Levy session tokens so you don't need /settoken on every restart
# If left empty, send /settoken in Telegram after the bot starts
RAMI_LEVY_API_KEY=
RAMI_LEVY_ECOM_TOKEN=
RAMI_LEVY_COOKIE=
